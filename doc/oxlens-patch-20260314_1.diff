+// author: kodeholic (powered by Claude)
+// OxLens Audio Interceptor — PTT silence injection + seq/ts offset 보정
+#ifndef OXLENS_AUDIO_INTERCEPTOR_H_
+#define OXLENS_AUDIO_INTERCEPTOR_H_
+
+#include <cstdint>
+#include <atomic>
+
+#include "api/task_queue/task_queue_base.h"
+#include "call/rtp_stream_receiver_controller.h"
+#include "modules/rtp_rtcp/source/rtp_packet_received.h"
+#include "system_wrappers/include/clock.h"
+
+namespace oxlens {
+
+class AudioInterceptor {
+ public:
+  virtual ~AudioInterceptor() = default;
+
+  // Call::SetAudioInterceptor() 에서 호출 — 내부 참조 연결
+  virtual void Attach(webrtc::TaskQueueBase* worker_thread,
+                      webrtc::RtpStreamReceiverController* audio_controller,
+                      webrtc::Clock* clock) = 0;
+
+  // on/off 제어 (JNI에서 호출)
+  virtual void SetEnabled(bool enabled) = 0;
+  virtual bool IsEnabled() const = 0;
+
+  // 실제 Audio RTP 패킷 인터셉트 — offset 보정
+  // return true: interceptor가 처리 완료 (Call skip)
+  // return false: Call이 보정된 packet을 계속 처리
+  virtual bool OnAudioRtpPacket(webrtc::RtpPacketReceived& packet) = 0;
+
+  // offset 리셋 (방 퇴장/재입장 시)
+  virtual void ResetOffset() = 0;
+
+  // silence injection 시작/정지 (PTT idle 진입/퇴출 시)
+  virtual void StartSilenceInjection(uint32_t ssrc) = 0;
+  virtual void StopSilenceInjection() = 0;
+
+  // Opus PT 설정 (server_config에서 가져온 값)
+  virtual void SetOpusPayloadType(uint8_t pt) = 0;
+};
+
+}  // namespace oxlens
+
+#endif  // OXLENS_AUDIO_INTERCEPTOR_H_
diff --git a/oxlens/audio_interceptor_impl.cc b/oxlens/audio_interceptor_impl.cc
new file mode 100644
index 0000000000..7717c9656e
--- /dev/null
+++ b/oxlens/audio_interceptor_impl.cc
@@ -0,0 +1,147 @@
+// author: kodeholic (powered by Claude)
+#include "oxlens/audio_interceptor_impl.h"
+
+#include <cstring>
+
+#include "api/units/time_delta.h"
+#include "api/units/timestamp.h"
+#include "rtc_base/logging.h"
+
+namespace oxlens {
+
+constexpr uint8_t AudioInterceptorImpl::kOpusSilence[];
+
+AudioInterceptorImpl::AudioInterceptorImpl() = default;
+
+AudioInterceptorImpl::~AudioInterceptorImpl() {
+  StopSilenceInjection();
+}
+
+void AudioInterceptorImpl::Attach(
+    webrtc::TaskQueueBase* worker_thread,
+    webrtc::RtpStreamReceiverController* audio_controller,
+    webrtc::Clock* clock) {
+  worker_thread_ = worker_thread;
+  audio_controller_ = audio_controller;
+  clock_ = clock;
+  RTC_LOG(LS_INFO) << "[OxLens] AudioInterceptor attached";
+}
+
+void AudioInterceptorImpl::SetEnabled(bool enabled) {
+  enabled_.store(enabled);
+  RTC_LOG(LS_INFO) << "[OxLens] AudioInterceptor " << (enabled ? "enabled" : "disabled");
+}
+
+bool AudioInterceptorImpl::IsEnabled() const {
+  return enabled_.load();
+}
+
+bool AudioInterceptorImpl::OnAudioRtpPacket(webrtc::RtpPacketReceived& packet) {
+  // Worker thread — real audio RTP packet arrived
+
+  if (need_offset_calc_) {
+    // First real packet after silence injection stopped
+    // Calculate offset: injected seq/ts → real seq/ts 연속 이어붙이기
+    uint16_t real_seq = packet.SequenceNumber();
+    uint32_t real_ts = packet.Timestamp();
+
+    seq_offset_ = static_cast<int32_t>(inject_seq_) -
+                  static_cast<int32_t>(real_seq) + 1;
+    ts_offset_ = static_cast<int64_t>(inject_ts_) -
+                 static_cast<int64_t>(real_ts) + kTimestampIncrement;
+
+    need_offset_calc_ = false;
+    RTC_LOG(LS_INFO) << "[OxLens] offset calc: seq_offset=" << seq_offset_
+                     << " ts_offset=" << ts_offset_
+                     << " (inject_seq=" << inject_seq_
+                     << " real_seq=" << real_seq << ")";
+  }
+
+  // Apply offset (서버 ingress.rs 로직과 동일)
+  if (seq_offset_ != 0 || ts_offset_ != 0) {
+    uint16_t new_seq = static_cast<uint16_t>(
+        static_cast<int32_t>(packet.SequenceNumber()) + seq_offset_);
+    uint32_t new_ts = static_cast<uint32_t>(
+        static_cast<int64_t>(packet.Timestamp()) + ts_offset_);
+    packet.SetSequenceNumber(new_seq);
+    packet.SetTimestamp(new_ts);
+  }
+
+  // return false → Call이 보정된 packet을 정상 경로로 처리
+  return false;
+}
+
+void AudioInterceptorImpl::ResetOffset() {
+  seq_offset_ = 0;
+  ts_offset_ = 0;
+  need_offset_calc_ = false;
+  inject_seq_ = 0;
+  inject_ts_ = 0;
+  RTC_LOG(LS_INFO) << "[OxLens] offset reset";
+}
+
+void AudioInterceptorImpl::SetOpusPayloadType(uint8_t pt) {
+  opus_pt_ = pt;
+  RTC_LOG(LS_INFO) << "[OxLens] opus PT set to " << static_cast<int>(pt);
+}
+
+void AudioInterceptorImpl::StartSilenceInjection(uint32_t ssrc) {
+  if (!worker_thread_ || !audio_controller_ || !clock_) {
+    RTC_LOG(LS_WARNING) << "[OxLens] StartSilenceInjection: not attached";
+    return;
+  }
+  if (injecting_) return;
+
+  target_ssrc_ = ssrc;
+  injecting_ = true;
+
+  silence_task_ = webrtc::RepeatingTaskHandle::Start(
+      worker_thread_,
+      [this]() -> webrtc::TimeDelta {
+        InjectSilenceFrame();
+        return webrtc::TimeDelta::Millis(kSilenceIntervalMs);
+      },
+      webrtc::TaskQueueBase::DelayPrecision::kHigh,
+      clock_);
+
+  RTC_LOG(LS_INFO) << "[OxLens] silence injection started ssrc="
+                   << ssrc
+                   << " seq=" << inject_seq_;
+}
+
+void AudioInterceptorImpl::StopSilenceInjection() {
+  if (!injecting_) return;
+
+  silence_task_.Stop();
+  injecting_ = false;
+  need_offset_calc_ = true;
+
+  RTC_LOG(LS_INFO) << "[OxLens] silence injection stopped"
+                   << " inject_seq=" << inject_seq_
+                   << " inject_ts=" << inject_ts_;
+}
+
+void AudioInterceptorImpl::InjectSilenceFrame() {
+  if (!audio_controller_ || !clock_) return;
+
+  // Synthetic RTP packet with Opus silence payload
+  webrtc::RtpPacketReceived packet;
+  packet.SetSsrc(target_ssrc_);
+  packet.SetPayloadType(opus_pt_);
+  packet.SetSequenceNumber(inject_seq_);
+  packet.SetTimestamp(inject_ts_);
+  packet.set_arrival_time(clock_->CurrentTime());
+
+  uint8_t* payload = packet.AllocatePayload(sizeof(kOpusSilence));
+  if (payload) {
+    memcpy(payload, kOpusSilence, sizeof(kOpusSilence));
+  }
+
+  // audio_receiver_controller_로 직접 전달 (Call::DeliverRtpPacket bypass)
+  audio_controller_->OnRtpPacket(packet);
+
+  inject_seq_++;
+  inject_ts_ += kTimestampIncrement;
+}
+
+}  // namespace oxlens
