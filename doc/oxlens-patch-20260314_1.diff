+  if (audio_interceptor_) audio_interceptor_->ResetOffset();
+}
+
+void PeerConnection::SetAudioInterceptorOpusPt(uint8_t pt) {
+  if (!audio_interceptor_) {
+    audio_interceptor_ = std::make_unique<oxlens::AudioInterceptorImpl>();
+    call_ptr_->SetAudioInterceptor(audio_interceptor_.get());
+  }
+  audio_interceptor_->SetOpusPayloadType(pt);
+}
