@@ -0,0 +1,69 @@
+// author: kodeholic (powered by Claude)
+#ifndef OXLENS_AUDIO_INTERCEPTOR_IMPL_H_
+#define OXLENS_AUDIO_INTERCEPTOR_IMPL_H_
+
+#include <atomic>
+#include <cstdint>
+
+#include "oxlens/audio_interceptor.h"
+#include "api/task_queue/task_queue_base.h"
+#include "api/units/time_delta.h"
+#include "call/rtp_stream_receiver_controller.h"
+#include "modules/rtp_rtcp/source/rtp_packet_received.h"
+#include "rtc_base/task_utils/repeating_task.h"
+#include "system_wrappers/include/clock.h"
+
+namespace oxlens {
+
+class AudioInterceptorImpl : public AudioInterceptor {
+ public:
+  AudioInterceptorImpl();
+  ~AudioInterceptorImpl() override;
+
+  void Attach(webrtc::TaskQueueBase* worker_thread,
+              webrtc::RtpStreamReceiverController* audio_controller,
+              webrtc::Clock* clock) override;
+
+  void SetEnabled(bool enabled) override;
+  bool IsEnabled() const override;
+  bool OnAudioRtpPacket(webrtc::RtpPacketReceived& packet) override;
+  void ResetOffset() override;
+  void StartSilenceInjection(uint32_t ssrc) override;
+  void StopSilenceInjection() override;
+  void SetOpusPayloadType(uint8_t pt) override;
+
+ private:
+  void InjectSilenceFrame();
+
+  std::atomic<bool> enabled_{false};
+  bool injecting_ = false;
+  uint32_t target_ssrc_ = 0;
+
+  // Silence injection seq/ts counters
+  uint16_t inject_seq_ = 0;
+  uint32_t inject_ts_ = 0;
+
+  // Offset for real packet correction
+  bool need_offset_calc_ = false;
+  int32_t seq_offset_ = 0;
+  int64_t ts_offset_ = 0;
+
+  // Opus PT (default 111, server_config에서 변경 가능)
+  uint8_t opus_pt_ = 111;
+
+  // Attached references (not owned)
+  webrtc::TaskQueueBase* worker_thread_ = nullptr;
+  webrtc::RtpStreamReceiverController* audio_controller_ = nullptr;
+  webrtc::Clock* clock_ = nullptr;
+
+  webrtc::RepeatingTaskHandle silence_task_;
+
+  // Opus DTX silence frame: TOC=0xf8 (48kHz, 20ms, code0) + silence data
+  static constexpr uint8_t kOpusSilence[] = {0xf8, 0xff, 0xfe};
+  static constexpr uint32_t kTimestampIncrement = 960;  // 48kHz * 20ms
+  static constexpr int64_t kSilenceIntervalMs = 20;
+};
+
+}  // namespace oxlens
+
+#endif  // OXLENS_AUDIO_INTERCEPTOR_IMPL_H_
